APP_ENV=local
APP_NAME=Assistente de Chamados TI
EXPOSE_DEBUG_ROUTES=true

GLPI_INTEGRATION_MODE=mock
GLPI_BASE_URL=
GLPI_APP_TOKEN=
GLPI_USER_TOKEN=
GLPI_DEFAULT_ENTITY_ID=3
GLPI_DEFAULT_PROFILE_ID=4
GLPI_DEFAULT_REQUESTER_USER_ID=0
GLPI_ALLOW_INSECURE_HTTP=false
GLPI_HTTP_TIMEOUT_SECONDS=20
GLPI_TICKET_PUBLIC_URL_TEMPLATE=
STATE_BACKEND=redis
REDIS_URL=redis://redis:6379/0
SESSION_LOCK_TIMEOUT_SECONDS=180
USE_CELERY_WORKERS=true
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
AI_QUEUE_NAME=ai_local
GLPI_QUEUE_NAME=glpi_io
AI_TASK_TIMEOUT_SECONDS=25

LOCAL_LIGHT_AI_MODE=generative_google
LOCAL_OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://ollama:11434
LOCAL_GENERATIVE_MODEL=qwen2.5:0.5b
LOCAL_GENERATIVE_TIMEOUT_SECONDS=30
GOOGLE_AI_API_KEY=
GOOGLE_AI_MODEL=gemini-3.1-flash-lite
GOOGLE_AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GOOGLE_AI_TIMEOUT_SECONDS=12
GOOGLE_AI_MAX_RETRIES=1
GOOGLE_AI_RATE_LIMIT_ENABLED=true
GOOGLE_AI_RPM_LIMIT=12
GOOGLE_AI_RPD_LIMIT=450
AI_GUIDED_DETAILING_ENABLED=true
AI_MAX_CLARIFICATION_QUESTIONS=1
AI_GENERATIVE_TITLE_ENABLED=false
AI_MAX_INPUT_CHARS=2000
AI_MAX_OUTPUT_CHARS=800
AI_OLLAMA_NUM_PREDICT=180
AI_OLLAMA_NUM_THREAD=4
AI_OLLAMA_TEMPERATURE=0.1
MAX_MESSAGE_LENGTH=3000

ALLOWED_NUMBERS=66999990980
ALLOW_ALL_NUMBERS=false
LOG_IGNORED_MESSAGES=false

TICKET_NOTIFICATIONS_ENABLED=false
TICKET_NOTIFICATION_POLL_INTERVAL_SECONDS=30
TICKET_NOTIFICATION_BATCH_SIZE=50
TICKET_NOTIFICATION_INTERNAL_NUMBERS=
TICKET_NOTIFICATION_INCLUDE_PRIVATE_EVENTS=true
TICKET_NOTIFICATION_WATCH_TTL_DAYS=30
WHATSAPP_OUTBOUND_BASE_URL=http://whatsapp:8081
WHATSAPP_INTERNAL_API_TOKEN=
